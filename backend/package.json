{
    "name": "hr-chatbot-backend",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "node --watch src/server.js",
        "start": "node src/server.js",
        "db:push": "npx prisma db push --schema=../database/prisma/schema.prisma",
        "db:seed": "node src/scripts/seed.js",
        "db:generate": "npx prisma generate --schema=../database/prisma/schema.prisma",
        "load-policies": "node src/scripts/loadPolicies.js"
    },
    "dependencies": {
        "@prisma/client": "^6.6.0",
        "axios": "^1.13.6",
        "chromadb": "^1.9.2",
        "cors": "^2.8.5",
        "dotenv": "^17.3.1",
        "express": "^5.1.0",
        "openai": "^4.104.0",
        "pdf-parse": "^1.1.1",
        "pdfkit": "^0.17.2"
    },
    "devDependencies": {
        "prisma": "^6.6.0"
    }
}
